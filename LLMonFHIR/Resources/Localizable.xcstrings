      "comment" : "A description of the health data that the app will access.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LLMonFHIR uses clinical health records stored on your device and accessed via HealthKit to provide context during the conversation.\n\nWhen participating in a study, you should grant LLMonFHIR **full access** to your clinical records; otherwise the study will not have sufficient context, and your participation cannot be evaluated consistently with participants who have granted full access.\n\nLLMonFHIR does not access any other health data outside of the conversation."
          }
        }
      }
    },
